# Variables partagées Docker Compose (racine du projet sur le serveur)
# Copier vers .env et db.env sur le serveur — ne pas committer les secrets.

# --- db.env (service database) ---
MONGO_INITDB_ROOT_USERNAME=portfolio
MONGO_INITDB_ROOT_PASSWORD=change-me
MONGO_INITDB_DATABASE=portfolio

# --- .env (service portfolio-backend) ---
PROJECT_NAME=Megitsune
PROJECT_URL=https://megitsune.xyz
BACKEND_URL=https://api.megitsune.xyz

RIOT_API_KEY=
RIOT_GAME_NAME=Megitsune
RIOT_TAG=0014
RIOT_SYNC_INTERVAL_MS=10800000

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
REDIRECT_ENDPOINT=/spotify/auth/callback
SPOTIFY_SYNC_INTERVAL_MS=900000

DISCORD_BOT_TOKEN=
DISCORD_USER_ID=

SESSION_SECRET=
NEXUS_MASTER_PASSWORD=

PORT=3000
NODE_ENV=production

# Surchargé par compose.yaml avec l'hôte Docker "database"
MONGODB_URL=mongodb://portfolio:change-me@database:27017/portfolio?authSource=portfolio
