# Project
PROJECT_NAME=Megitsune
PROJECT_URL=https://megitsune.xyz
BACKEND_URL=https://api.megitsune.xyz

# Riot Games API
RIOT_API_KEY=API-KEY
RIOT_GAME_NAME=Megitsune
RIOT_TAG=0014
RIOT_SYNC_INTERVAL_MS=10800000

# Spotify API
SPOTIFY_CLIENT_ID=SPOTIFY-CLIENT-ID
SPOTIFY_CLIENT_SECRET=SPOTIFY-CLIENT-SECRET
REDIRECT_ENDPOINT=/spotify/auth/callback
SPOTIFY_SYNC_INTERVAL_MS=900000
SPOTIFY_TOP_LIMIT=50
SPOTIFY_ARTIST_ENRICH_BATCH_SIZE=50
SPOTIFY_ARTIST_ENRICH_DELAY_MS=150
SPOTIFY_ARTIST_ENRICH_MAX_PER_SYNC=500
SPOTIFY_ARTIST_ENRICH_TTL_DAYS=30

# Discord Bot API - numeric user ID (snowflake), not the vanity username
DISCORD_BOT_TOKEN=YOUR-BOT-TOKEN
DISCORD_USER_ID=YOUR-DISCORD-USER-ID

# Session Secret
SESSION_SECRET=blblblblblblblbl

# Nexus Dashboard
NEXUS_MASTER_PASSWORD=your-master-password

# MongoDB
MONGODB_URL=mongodb://localhost:27017/portfolio

# Server
PORT=3000
NODE_ENV=development